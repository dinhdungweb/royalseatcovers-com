<style>
  .protection-section-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px;
    max-width: 1200px;
    margin: 0 auto;
    box-sizing: border-box;
  }
  .protection-heading-{{ section.id }} {
    text-align: center;
    font-size: 32px;
    font-weight: bold;
    margin-bottom: 40px;
    color: #222;
    letter-spacing: 0.5px;
  }
  .protection-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .protection-card-{{ section.id }} {
    display: flex;
    flex-direction: column;
    background-color: #1f1f1f; /* Màu nền đen xám giống thiết kế */
    color: #ffffff;
    overflow: hidden;
  }
  .protection-image-wrapper-{{ section.id }} {
    width: 100%;
    aspect-ratio: 16 / 10;
    position: relative;
    background: #333;
  }
  .protection-image-wrapper-{{ section.id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .protection-text-wrapper-{{ section.id }} {
    padding: 24px 15px;
    text-align: center;
  }
  .protection-text-wrapper-{{ section.id }} h3 {
    font-size: 18px;
    margin: 0 0 8px 0;
    color: #ffffff;
    font-weight: 700;
  }
  .protection-text-wrapper-{{ section.id }} p {
    font-size: 14px;
    margin: 0;
    color: #a3a3a3; /* Màu xám nhạt cho mô tả */
    line-height: 1.4;
  }

  /* Reponsive cho điện thoại và máy tính bảng */
  @media (max-width: 768px) {
    .protection-grid-{{ section.id }} {
      grid-template-columns: 1fr; /* Chuyển thành 1 cột trên điện thoại */
    }
    .protection-heading-{{ section.id }} {
      font-size: 26px;
      margin-bottom: 30px;
    }
  }
</style>

<div class="protection-section-{{ section.id }}">
  {% if section.settings.title != blank %}
    <h2 class="protection-heading-{{ section.id }}">{{ section.settings.title }}</h2>
  {% endif %}

  <div class="protection-grid-{{ section.id }}">
    {% for block in section.blocks %}
      <div class="protection-card-{{ section.id }}" {{ block.shopify_attributes }}>
        <div class="protection-image-wrapper-{{ section.id }}">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url: width: 600 }}" 
                 alt="{{ block.settings.title | escape }}" 
                 loading="lazy">
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>
        
        <div class="protection-text-wrapper-{{ section.id }}">
          {% if block.settings.title != blank %}
            <h3>{{ block.settings.title }}</h3>
          {% endif %}
          
          {% if block.settings.description != blank %}
            <p>{{ block.settings.description }}</p>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Protection Features",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Protection That Holds Up"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 6,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Short description about this feature."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Protection Features",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "Taped Seams",
            "description": "Blocks water at the seams"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Wind Straps",
            "description": "Keeps the cover secure in strong winds"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Air Vents",
            "description": "Prevents heat and moisture buildup"
          }
        }
      ]
    }
  ]
}
{% endschema %}