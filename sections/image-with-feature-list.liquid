{{ 'custom-content.css' | asset_url | stylesheet_tag }}

{% liquid
  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif

  assign classes = 'm-section m-image-features' | append: ' m-gradient m-color-' | append: section.settings.color_scheme
%}

<style>
        #m-section-{{ section.id }} {
          --section-padding-top: {{ section.settings.padding_top }}px;
          --section-padding-bottom: {{ section.settings.padding_bottom }}px;
        }

        /* ===== TOP HEADER BLOCK ===== */
        .image-features__top-header {
          text-align: center;
          margin-bottom: {{ section.settings.header_margin_bottom }}px;
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
        }

        .image-features__top-subheading {
          font-size: 14px;
          font-weight: 600;
          letter-spacing: 0.1em;
          text-transform: uppercase;
          margin: 0 0 12px 0;
          color: rgba(var(--color-foreground), 0.7);
        }

        .image-features__top-heading {
          font-size: clamp(28px, 4vw, 42px);
          font-weight: 800;
          line-height: 1.15;
          margin: 0;
          letter-spacing: -0.02em;
          text-transform: uppercase;
          color: inherit;
        }

        /* ===== IMAGE BLOCK (LEFT) ===== */
        .image-features__image-wrap {
          position: relative;
          border-radius: 8px;
          overflow: hidden;
          display: block;
        }

        .image-features__image-wrap img {
          width: 100%;
          height: auto;
          display: block;
        }

        /* Overlay gradient at bottom of image */
        .image-features__image-overlay {
          position: absolute;
          bottom: 0;
          left: 0;
          right: 0;
          padding: 28px 28px 32px;
          background: linear-gradient(to top, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.15) 70%, transparent 100%);
          color: #fff;
        }

        .image-features__image-overlay h3 {
          margin: 0 0 14px 0;
          font-size: 22px;
          font-weight: 700;
          line-height: 1.25;
          letter-spacing: -0.01em;
          color: #fff;
        }

        .image-features__overlay-btn {
          display: inline-flex;
          align-items: center;
          gap: 6px;
          color: #fff;
          font-weight: 600;
          font-size: 14px;
          text-decoration: none;
          border: none;
          background: none;
          padding: 0;
          cursor: pointer;
          letter-spacing: 0.02em;
          transition: gap 0.2s ease;
        }

        .image-features__overlay-btn:hover {
          gap: 10px;
        }

        .image-features__overlay-btn svg {
          width: 16px;
          height: 16px;
          flex-shrink: 0;
        }

        /* ===== CONTENT BLOCK (RIGHT) ===== */
        .image-features__content {
          padding-left: 0;
        }

        @media (min-width: 1024px) {
          .image-features__content {
            padding-left: 64px;
          }
        }

        .feature-list__title {
          margin: 0 0 36px 0;
          font-weight: 800;
          font-size: clamp(22px, 3vw, 32px);
          line-height: 1.15;
          letter-spacing: -0.02em;
          text-transform: uppercase;
          color: inherit;
        }

        /* ===== FEATURE ITEMS ===== */
        .feature-list__wrapper {
          display: flex;
          flex-direction: column;
          gap: 0;
        }

        .feature-item {
          display: flex;
          align-items: flex-start;
          gap: 20px;
          padding: 18px 0;
          border-bottom: 1px solid rgba(0,0,0,0.07);
        }

        .feature-item:last-child {
          border-bottom: none;
        }

        .feature-item__icon {
          flex-shrink: 0;
          width: 52px;
          height: 52px;
          display: flex;
          align-items: center;
          justify-content: center;
          background: #7b7b7b;
          border-radius: 50%;
        }

        .feature-item__icon img {
          width: 26px;
          height: 26px;
          object-fit: contain;
        }

        .feature-item__icon .placeholder-icon {
          width: 26px;
          height: 26px;
          opacity: 0.45;
        }

        .feature-item__content {
          padding-top: 4px;
        }

        .feature-item__content h4 {
          margin: 0 0 4px 0;
          font-weight: 700;
          font-size: 15px;
          line-height: 1.3;
          letter-spacing: -0.01em;
          color: inherit;
        }

        .feature-item__content p {
          margin: 0;
          font-size: 14px;
          line-height: 1.5;
          color: rgba(var(--color-foreground), 0.6);
        }

      @media (max-width: 768px){
        .image-features__content{
          margin-top: 20px;
        }

        .feature-list__title{
          margin-bottom: 28px;
        }

        /* Bổ sung căn lề cho Section Heading trên mobile */
        #m-section-{{ section.id }} .feature-list__title {
          text-align: {{ section.settings.heading_alignment_mobile }};
        }
      }
</style>

<div id="m-section-{{ section.id }}" class="{{ classes }}">
  <div class="{{ container }} m-section-my m-section-py">
    {%- comment -%} TOP HEADER SECTION {%- endcomment -%}
    {% if section.settings.top_heading != blank or section.settings.top_subheading != blank %}
      <div class="image-features__top-header">
        {% if section.settings.top_subheading != blank %}
          <div class="image-features__top-subheading">{{ section.settings.top_subheading }}</div>
        {% endif %}
        {% if section.settings.top_heading != blank %}
          <h2 class="image-features__top-heading">{{ section.settings.top_heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    <div
      class="
        m:flex m:flex-wrap m:items-start
        {% if section.settings.layout == 'image_right' %}
          lg:m:flex-row-reverse
        {% endif %}
      "
    >
      <div class="m:column m:w-full lg:m:w-1/2">
        <div class="image-features__image-wrap">
          {% if section.settings.main_image != blank %}
            <img
              src="{{ section.settings.main_image | image_url: width: 1200 }}"
              alt="{{ section.settings.image_caption | escape }}"
              loading="lazy"
              width="{{ section.settings.main_image.width }}"
              height="{{ section.settings.main_image.height }}"
            >
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'm-placeholder-svg' }}
          {% endif %}

          {% if section.settings.image_caption != blank or section.settings.image_button_label != blank %}
            <div class="image-features__image-overlay">
              {% if section.settings.image_caption != blank %}
                <h3>{{ section.settings.image_caption }}</h3>
              {% endif %}
              {% if section.settings.image_button_label != blank %}
                <a href="{{ section.settings.button_link }}" class="image-features__overlay-btn">
                  {{ section.settings.image_button_label }}
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M5 12h14M12 5l7 7-7 7"/>
                  </svg>
                </a>
              {% endif %}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="m:column m:w-full lg:m:w-1/2 image-features__content m:mt-8 lg:m:mt-0">
        {% if section.settings.heading != blank %}
          <h2 class="feature-list__title {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {% endif %}

        <div class="feature-list__wrapper">
          {% for block in section.blocks %}
            {% if block.type == 'feature_item' %}
              <div class="feature-item" {{ block.shopify_attributes }}>
                <div class="feature-item__icon">
                  {% if block.settings.icon != blank %}
                    <img
                      src="{{ block.settings.icon | image_url: width: 100 }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                      width="{{ block.settings.icon.width }}"
                      height="{{ block.settings.icon.height }}"
                    >
                  {% else %}
                    <svg
                      class="placeholder-icon"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1.5"
                    >
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <path d="M21 15l-5-5L5 21"/>
                    </svg>
                  {% endif %}
                </div>
                <div class="feature-item__content">
                  <h4>{{ block.settings.title }}</h4>
                  <p>{{ block.settings.text }}</p>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with Feature List",
  "settings": [
    {
      "type": "header",
      "content": "Top Section Header"
    },
    {
      "type": "text",
      "id": "top_subheading",
      "label": "Top Subheading",
      "default": "WHY COVERLAND?"
    },
    {
      "type": "text",
      "id": "top_heading",
      "label": "Top Heading",
      "default": "Tailored. Tested. Trusted."
    },
    {
      "type": "range",
      "id": "header_margin_bottom",
      "label": "Spacing bottom (Header to Content)",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Main Image"
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main Image"
    },
    {
      "type": "text",
      "id": "image_caption",
      "label": "Image Caption (overlay text)",
      "default": "Custom-Fit Seat Covers"
    },
    {
      "type": "text",
      "id": "image_button_label",
      "label": "Image Button Label (inside image)",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link (used by image overlay button)"
    },
    {
      "type": "header",
      "content": "Right Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "SEAT COVERS THAT FIT. AND STAY."
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "default": "h2",
      "options": [
        { "value": "h2", "label": "Medium" },
        { "value": "h1", "label": "Large" }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment_mobile",
      "label": "Heading Alignment (Mobile)",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Layout & Color"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "default": "image_left",
      "options": [
        { "value": "image_left", "label": "Image Left / Text Right" },
        { "value": "image_right", "label": "Image Right / Text Left" }
      ]
    },
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container-fluid",
      "options": [
        { "value": "container-fluid", "label": "Default" },
        { "value": "w-full", "label": "Full width" },
        { "value": "container", "label": "Use container box" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "feature_item",
      "name": "Feature Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Custom-Fit Design"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Tailored for your exact vehicle."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with Feature List",
      "blocks": [{ "type": "feature_item" }]
    }
  ]
}
{% endschema %}