<div class="vehicle-config-stepper section-{{ section.id }}" data-section-id="{{ section.id }}">
  {%- liquid
    assign product_form_id = 'product-form-' | append: section.id
  -%}
  
  <div class="stepper-container">
    
    <!-- Step 1: Vehicle Details -->
    <div class="stepper-item active" id="step-1-container">
      <div class="stepper-marker">
        <div class="stepper-number">1</div>
        <div class="stepper-line"></div>
      </div>
      <div class="stepper-content">
        <h3 class="stepper-title">Vehicle Details</h3>
        <div class="stepper-pane">
           {% render 'vehicle-selector', product_form_id: product_form_id %}
           <div id="vehicle-validation-message" style="color: #BE1B1B; font-size: 13px; font-weight: 600; margin-top: 10px; display: none;">
             * Please select all info vehicle
           </div>
        </div>
      </div>
    </div>

    <variant-picker
      id="variant-picker-{{ section.id }}"
      data-product-id="{{ product.id }}"
      data-section-id="{{ section.id }}"
      data-update-url="true"
      data-product-url="{{ product.url }}"
      data-has-only-default-variant="{{ product.has_only_default_variant }}"
    >
      <!-- Step 2: Color Selection -->
      <div class="stepper-item" id="step-2-container">
        <div class="stepper-marker">
          <div class="stepper-number">2</div>
          <div class="stepper-line"></div>
        </div>
        <div class="stepper-content">
          <h3 class="stepper-title">Color - <span id="selected-color-name">{{ product.selected_or_first_available_variant.options[0] }}</span></h3>
          <div class="stepper-pane">
             {% render 'product-color-picker', product: product, product_form_id: product_form_id %}
          </div>
        </div>
      </div>

      <!-- Step 3: Choose Your Setup -->
      <div class="stepper-item" id="step-3-container">
        <div class="stepper-marker">
          <div class="stepper-number">3</div>
        </div>
        <div class="stepper-content">
          <h3 class="stepper-title">Choose Your Setup</h3>
          <div class="stepper-pane">
             {% render 'product-setup-picker', product: product, product_form_id: product_form_id %}
          </div>
        </div>
      </div>
      
      <script type="application/json" data-selected-variant>
        {{ product.selected_or_first_available_variant | json }}
      </script>
    </variant-picker>

  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    // 1. Vehicle Selection Logic (Ported and unified)
    const yearSelect = document.getElementById('vehicle-year');
    const makeSelect = document.getElementById('vehicle-make');
    const modelSelect = document.getElementById('vehicle-model');
    const trimSelect = document.getElementById('vehicle-trim');
    const cabSelect = document.getElementById('vehicle-cab');
    const validationMessage = document.getElementById('vehicle-validation-message');
    const atcButton = document.querySelector('.m-add-to-cart');
    const trimWrapper = document.getElementById('trim-wrapper');
    const cabWrapper = document.getElementById('cab-wrapper');

    const allOptions = {
      make: Array.from(makeSelect.options),
      model: Array.from(modelSelect.options),
      trim: Array.from(trimSelect.options),
      cab: Array.from(cabSelect.options)
    };

    function initSelect(select, placeholder) {
      select.innerHTML = `<option value="">${placeholder}</option>`;
      select.disabled = true;
    }

    function updateDropdown(targetSelect, optionsArr, dataAttr, parentVal, placeholder) {
      targetSelect.innerHTML = `<option value="">${placeholder}</option>`;
      let matchFound = false;
      optionsArr.forEach(opt => {
        if (!dataAttr || opt.getAttribute(dataAttr) === parentVal || opt.value === "") {
          if (opt.value !== "") {
            targetSelect.appendChild(opt.cloneNode(true));
            matchFound = true;
          }
        }
      });
      targetSelect.disabled = !matchFound;
      return matchFound;
    }

    function validateAndSyncSteps() {
      const trimRequired = !trimSelect.disabled;
      const cabRequired = !cabSelect.disabled;
      const vehicleDone = yearSelect.value && makeSelect.value && modelSelect.value && (!trimRequired || trimSelect.value) && (!cabRequired || cabSelect.value);
      
      // Step 1 status
      if (vehicleDone) {
        document.getElementById('step-1-container').classList.add('completed');
        document.getElementById('step-2-container').classList.add('active');
        if (validationMessage) validationMessage.style.display = 'none';
      } else {
        document.getElementById('step-1-container').classList.remove('completed');
        if (validationMessage) validationMessage.style.display = 'block';
      }

      // ATC Button state
      if (atcButton) {
        if (vehicleDone) {
          atcButton.disabled = false;
          atcButton.style.opacity = '1';
          atcButton.style.pointerEvents = 'auto';
        } else {
          atcButton.disabled = true;
          atcButton.style.opacity = '0.5';
          atcButton.style.pointerEvents = 'none';
        }
      }
    }

    yearSelect.addEventListener('change', function() {
      updateDropdown(makeSelect, allOptions.make, null, null, 'Select Make');
      initSelect(modelSelect, 'Select Model');
      initSelect(trimSelect, 'Select Trim');
      initSelect(cabSelect, 'Select Cab Size');
      validateAndSyncSteps();
    });

    makeSelect.addEventListener('change', function() {
      updateDropdown(modelSelect, allOptions.model, 'data-make', this.value, 'Select Model');
      initSelect(trimSelect, 'Select Trim');
      initSelect(cabSelect, 'Select Cab Size');
      validateAndSyncSteps();
    });

    modelSelect.addEventListener('change', function() {
      const hasTrim = updateDropdown(trimSelect, allOptions.trim, 'data-model', this.value, 'Select Trim');
      initSelect(cabSelect, 'Select Cab Size');
      if (this.value && hasTrim) {
        if (trimWrapper) trimWrapper.style.display = 'block';
      } else {
        if (trimWrapper) trimWrapper.style.display = 'none';
      }
      if (cabWrapper) cabWrapper.style.display = 'none';
      validateAndSyncSteps();
    });

    trimSelect.addEventListener('change', function() {
      const hasCab = updateDropdown(cabSelect, allOptions.cab, 'data-trim', this.value, 'Select Cab Size');
      if (this.value && hasCab) {
        if (cabWrapper) cabWrapper.style.display = 'block';
      } else {
        if (cabWrapper) cabWrapper.style.display = 'none';
      }
      validateAndSyncSteps();
    });

    cabSelect.addEventListener('change', validateAndSyncSteps);

    // Initial check
    validateAndSyncSteps();
  });
</script>

{% schema %}
{
  "name": "Vehicle Config Stepper",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Customize Your Cover"
    }
  ],
  "presets": [
    {
      "name": "Vehicle Config Stepper"
    }
  ]
}
{% endschema %}
