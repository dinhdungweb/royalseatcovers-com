<section class="category-cards">
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="category-heading">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="category-subheading">
        {{ section.settings.subheading }}
      </p>
    {% endif %}

    <div class="category-grid">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link }}"
          class="category-card"
          {{ block.shopify_attributes }}
        >
          <div class="category-text">
            <h3 class="category-title">
              {{ block.settings.title }}
            </h3>

            <p class="category-subtitle">
              {{ block.settings.subtitle }}
            </p>
          </div>

          <div class="category-image">
            {{ block.settings.image | image_url: width: 400 | image_tag }}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
                .category-heading{
                  text-align:center;
                  font-size:32px;
                  font-weight:700;
                }

                .category-subheading{
                  text-align:center;
                  margin-top:10px;
                  color:#666;
                }

                .category-grid{
                  margin-top:40px;
                  display:grid;
                  grid-template-columns:repeat(3,1fr);
                  gap:20px;
                }

                .category-card{
    display:flex;
    align-items:center;
    justify-content:space-between;
    background:#f5f5f5;
    border-radius:12px;
    padding:20px;
    gap:20px;

    text-decoration:none;
    color:inherit;

    transition:all .25s;
      }

      .category-card{
      transition:all .25s;
    }

    .category-card:hover{
      transform:translateY(-4px);
      box-shadow:0 10px 20px rgba(0,0,0,.08);
    }

              /* TEXT 30% */
              .category-text{
                flex:0 0 30%;
              }

              /* IMAGE 70% */
.category-image{
  flex:0 0 70%;
  display:flex;
  justify-content:flex-end;
  align-items:center;
}

.category-image img{
  width:100%;
  max-width:{{ section.settings.image_size }}px;
  height:auto;
  object-fit:contain;
}

.category-text{
  flex:0 0 30%;
  padding-left:10px;
}

              /* MOBILE */
             @media(max-width:768px){

    .category-grid{
      grid-template-columns:1fr;
      gap:16px;
    }

    .category-card{
      flex-direction:column;
      text-align:center;
    }

    .category-image{
      order:-1;
      margin-bottom:12px;
    }

    .category-text{
      text-align:center;
    }

    .category-image img{
      max-width:{{ section.settings.image_size | divided_by: 1.5 }}px;
    }

  }
</style>

{% schema %}
{
  "name": "Category cards",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Header text",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub header",
      "default": "Find the perfect accessories for your car"
    },
    {
      "type": "range",
      "id": "image_size",
      "label": "Image size",
      "min": 60,
      "max": 500,
      "step": 10,
      "default": 180,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Category Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Seat Covers"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Front Seat / Full Set"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Category Cards",
      "blocks": [{ "type": "card" }, { "type": "card" }, { "type": "card" }]
    }
  ]
}
{% endschema %}
