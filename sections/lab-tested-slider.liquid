{% liquid
  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif
%}
{%- style -%}
  #LabTested-{{ section.id }} .lab-slider-container {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  #LabTested-{{ section.id }} .lab-tested-heading {
    margin-top: {{ section.settings.heading_margin_top }}px;
  }
{%- endstyle -%}

<div id="LabTested-{{ section.id }}" class="lab-tested-section">
  <div class="{{ container }}">
    {% if section.settings.heading != blank %}
      <h2 class="lab-tested-heading {{ section.settings.heading_size }}" style="color: {{ section.settings.heading_color }};">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    <div class="lab-slider-container" style="background-color: {{ section.settings.bg_color }};">
      <div class="lab-slider-wrapper" id="LabSlider-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="lab-slide lab-slide--{{ block.type }}" {{ block.shopify_attributes }}>
            <div class="lab-slide-inner">
              <div class="lab-slide-media">
                {% if block.type == 'video_slide' %}
                  {% if block.settings.hosted_video != blank %}
                    {{
                      block.settings.hosted_video
                      | video_tag:
                        controls: true,
                        muted: true,
                        autoplay: block.settings.autoplay_video,
                        loop: block.settings.loop_video,
                        image_size: '800x'
                    }}
                  {% else %}
                    {{ 'video' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}

                {% elsif block.type == 'image_slide' %}
                  {% if block.settings.image != blank %}
                    <img
                      src="{{ block.settings.image | img_url: '800x' }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                    >
                  {% else %}
                    {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                  {% endif %}
                {% endif %}
              </div>

              <div class="lab-slide-content">
                {% if block.settings.title != blank %}
                  <h3 style="color: {{ block.settings.title_color }};">{{ block.settings.title }}</h3>
                {% endif %}

                {% if block.settings.text != blank %}
                  <p style="color: {{ block.settings.text_color }};">{{ block.settings.text | newline_to_br }}</p>
                {% endif %}

                {% if block.settings.btn_label != blank and block.settings.btn_link != blank %}
                  <a
                    href="{{ block.settings.btn_link }}"
                    class="lab-slide-btn"
                    style="
                      --btn-text: {{ block.settings.btn_text }};
                      --btn-bg: {{ block.settings.btn_bg }};
                      --btn-border: {{ block.settings.btn_border }};
                      --btn-text-hover: {{ block.settings.btn_text_hover }};
                      --btn-bg-hover: {{ block.settings.btn_bg_hover }};
                      --btn-border-hover: {{ block.settings.btn_border_hover }};
                    "
                  >
                    {{ block.settings.btn_label }}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.show_arrows %}
        <div class="lab-slider-arrows">
          <button class="lab-slider-arrow prev-arrow" onclick="scrollLabSlider('{{ section.id }}', -1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
          </button>
          <button class="lab-slider-arrow next-arrow" onclick="scrollLabSlider('{{ section.id }}', 1)">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>
        </div>
      {% endif %}

      {% if section.settings.show_dots %}
        <div class="lab-slider-dots" id="LabDots-{{ section.id }}">
          {% for block in section.blocks %}
            <span
              class="lab-dot {% if forloop.first %}active{% endif %}"
              onclick="goToLabSlide('{{ section.id }}', {{ forloop.index0 }})"
            ></span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

<style>
  .lab-tested-section {
    width: 100%;
  }
.lab-tested-heading {
    text-align: center;
    text-transform: uppercase;
    margin-bottom: 30px;
    
    /* Copy y hệt "form dáng" của section kia */
    font-weight: 800; 
    line-height: 1.15;
    letter-spacing: -0.02em;
  }

  /* Ép cỡ chữ khi chọn Medium (h2) */
  .lab-tested-heading.h2 {
    font-size: clamp(22px, 3vw, 32px) !important;
  }

  /* Ép cỡ chữ khi chọn Large (h1) */
  .lab-tested-heading.h1 {
    font-size: clamp(28px, 4vw, 42px) !important;
  }
  .lab-slider-container {
    position: relative;
    border-radius: 8px;
    overflow: hidden;

  }
  .lab-slider-wrapper {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .lab-slider-wrapper::-webkit-scrollbar {
    display: none;
  }
  .lab-slide {
    flex: 0 0 100%;
    scroll-snap-align: start;
    padding: 0 40px;
    box-sizing: border-box;
  }
  .lab-slide-inner {
    display: flex;
    align-items: center;
    gap: 60px;
    max-width: 1000px;
    margin: 0 auto;
  }
  .lab-slide-media {
    flex: 1;
    border-radius: 6px;
    overflow: hidden;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    background: #000;
  }
  .lab-slide-media img, .lab-slide-media video {
    width: 100%;
    height: auto;
    max-height: 500px;
    display: block;
    object-fit: contain;
  }
  .placeholder-svg {
    background: #333;
    fill: #666;
    width: 100%;
  }
  .lab-slide-content {
    flex: 1;
  }
  .lab-slide-content h3 {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 20px;
    line-height: 1.2;
  }
  .lab-slide-content p {
    font-size: 16px;
    line-height: 1.6;
    margin-bottom: 30px;
  }

  /* Button Styles */
  .lab-slide-btn {
    display: inline-block;
    padding: 14px 28px;
    font-weight: 700;
    font-size: 15px;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s ease;
    color: var(--btn-text);
    background: var(--btn-bg);
    border: 1px solid var(--btn-border);
  }
  .lab-slide-btn:hover {
    color: var(--btn-text-hover);
    background: var(--btn-bg-hover);
    border-color: var(--btn-border-hover);
  }

  /* Arrows */
  .lab-slider-arrows {
    position: absolute;
    bottom: 30px;
    right: 40px;
    display: flex;
    gap: 10px;
    z-index: 2;
  }
  .lab-slider-arrow {
    background: #333;
    color: #fff;
    border: none;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
    transition: all 0.3s ease;
  }
  .lab-slider-arrow:hover {
    opacity: 1;
    background: #444;
  }
  .lab-slider-arrow svg { width: 20px; height: 20px; }

  /* Dots */
  .lab-slider-dots {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
  }
  .lab-dot {
    display: inline-block;
    width: 6px;
    height: 6px;
    background: #666;
    border-radius: 50%;
    cursor: pointer;
    transition: background 0.3s;
  }
  .lab-dot.active {
    background: #fff;
    transform: scale(1.2);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .lab-slide-inner {
      flex-direction: column;
      gap: 30px;
    }
    .lab-slide {
      padding: 0 20px;
    }
    .lab-slide-content h3 {
      font-size: 24px;
    }
    .lab-slider-arrows {
      display: none;
    }
    .lab-slider-container {
      padding: 40px 0 60px 0;
    }
  }
</style>

<script>
  function scrollLabSlider(sectionId, direction) {
    const wrapper = document.getElementById(`LabSlider-${sectionId}`);
    if (!wrapper) return;
    const slideWidth = wrapper.clientWidth;
    const currentIndex = Math.round(wrapper.scrollLeft / slideWidth);
    wrapper.scrollTo({ left: slideWidth * (currentIndex + direction), behavior: 'smooth' });
  }

  function goToLabSlide(sectionId, index) {
    const wrapper = document.getElementById(`LabSlider-${sectionId}`);
    if (!wrapper) return;
    const slideWidth = wrapper.clientWidth;
    wrapper.scrollTo({ left: slideWidth * index, behavior: 'smooth' });
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.lab-slider-wrapper').forEach((wrapper) => {
      wrapper.addEventListener('scroll', (e) => {
        const sectionId = wrapper.id.replace('LabSlider-', '');
        const slideWidth = wrapper.clientWidth;
        const currentIndex = Math.round(wrapper.scrollLeft / slideWidth);

        const dots = document.querySelectorAll(`#LabDots-${sectionId} .lab-dot`);
        dots.forEach((dot, index) => {
          if (index === currentIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      });
    });
  });
</script>

