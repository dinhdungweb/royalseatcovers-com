{% comment %}
  Vehicle Finder Section - Metaobject Version (Customizable)
{% endcomment %}

{% assign years = shop.metaobjects.year.values %}
{% assign makes = shop.metaobjects.make.values %}
{% assign models = shop.metaobjects.model.values %}

<section class="vehicle-finder" style="background: {{ section.settings.bg_color }};">
  <div class="page-width">
    <h2 class="finder-title" style="color: {{ section.settings.text_color }};">
      {{ section.settings.heading }}
    </h2>

    <div class="finder-grid">
      <!-- PRODUCT -->
      <select id="vf-product">
        <option value="">1 - Select Product</option>
        {% for product in collections.all.products %}
          <option value="{{ product.handle }}">
             {{ product.title | truncate: 35 }}
          </option>
        {% endfor %}
      </select>

      <!-- YEAR -->
      <select id="vf-year">
        <option value="">2 - Year</option>
        {% paginate shop.metaobjects.year.values by 200 %}
          {% assign years = shop.metaobjects.year.values | reverse %}
          {% for year in years %}
            <option value="{{ year.year }}">{{ year.year }}</option>
          {% endfor %}
        {% endpaginate %}
      </select>

      <!-- MAKE -->
      <select id="vf-make">
        <option value="">3 - Make</option>
        {% paginate shop.metaobjects.make.values by 500 %}
          {% for make in shop.metaobjects.make.values %}
            <option value="{{ make.make }}">
              {{ make.make }}
            </option>
          {% endfor %}
        {% endpaginate %}
      </select>

      <!-- MODEL -->
      <select id="vf-model" disabled>
        <option value="">4 - Model</option>
        {% paginate shop.metaobjects.model.values by 500 %}
          {% for model in shop.metaobjects.model.values %}
            <option
              value="{{ model.model }}"
              data-make="{{ model.make.value.make }}"
            >
              {{ model.model }}
            </option>
          {% endfor %}
        {% endpaginate %}
      </select>

      <button
        id="vf-go"
        disabled
        style="background: {{ section.settings.button_color }}; color: {{ section.settings.button_text_color }};"
      >
        {{ section.settings.button_text }}
      </button>
    </div>
  </div>
</section>

<style>
    .vehicle-finder {
      padding: 50px 20px;
      text-align: center;
    }

    .finder-title {
      margin-bottom: 30px;
      font-size: 26px;
      font-weight: 600;
    }

    .finder-grid{
      display:grid;
      grid-template-columns:repeat(5,1fr);
      gap:15px;
      max-width:1000px;
      margin:auto;
    }

    .vehicle-finder select{
      width:100%;
      padding:14px;
      background:#222;
      color:#fff;
      border:1px solid #444;
      border-radius:4px;

      white-space:nowrap;
      overflow:hidden;
      text-overflow:ellipsis;
    }
    #vf-go{
      width:100%;
      padding:14px;
      border:none;
      cursor:pointer;
      opacity:0.5;
      border-radius:4px;
      transition:0.3s ease;
    }

    #vf-go.enabled {
      opacity: 1;
    }

    /* Tablet */
  @media (max-width: 1024px) {
    .vehicle-finder {
      padding: 40px 20px;
    }

    .finder-title {
      font-size: 22px;
      margin-bottom: 25px;
    }

    .finder-grid {
      flex-direction: column;
      align-items: center;
      max-width: 500px;
      margin: 0 auto;
      gap: 12px;
    }

    .vehicle-finder select {
      width: 100%;
      min-width: unset;
      font-size: 15px;
    }

    #vf-go {
      width: 100%;
      padding: 16px;
      font-size: 16px;
    }
  }

  /* Mobile */
  @media (max-width: 640px) {
    .vehicle-finder {
      padding: 30px 15px;
    }

    .finder-title {
      font-size: 20px;
    }

    .vehicle-finder select {
      padding: 12px;
      font-size: 14px;
    }

    #vf-go {
      padding: 14px;
      font-size: 15px;
    }
  }
  {% comment %}luc update mobile {% endcomment %}
  @media (max-width: 767px) {
  .finder-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }
}

@media (max-width: 767px) {
  #vf-go {
    grid-column: 1 / -1 !important; 
    width: 100% !important; 
    margin-top: 10px; 
  }
}
</style>

