<script>
  document.addEventListener('DOMContentLoaded', function () {
    const productSelect = document.getElementById('vf-product');
    const yearSelect = document.getElementById('vf-year');
    const makeSelect = document.getElementById('vf-make');
    const modelSelect = document.getElementById('vf-model');
    const btn = document.getElementById('vf-go');

    // 1. Lưu bản gốc của tất cả các Model vào bộ nhớ JavaScript và xóa chúng khỏi DOM
    const allModelOptions = Array.from(modelSelect.querySelectorAll("option:not([value=''])"));
    modelSelect.innerHTML = '<option value="">4 - Model</option>';

    function filterModels(selectedMake) {
      // Xóa sạch danh sách hiện tại trong ô Model
      modelSelect.innerHTML = '<option value="">4 - Model</option>';
      
      if (!selectedMake) {
        modelSelect.disabled = true;
        return;
      }

      // 2. Chỉ lọc và THÊM NHỮNG OPTION KHỚP vào lại thẻ Select
      let hasValidModels = false;
      allModelOptions.forEach((option) => {
        if (option.dataset.make === selectedMake) {
          // Clone (nhân bản) option để đưa vào lại thẻ select
          modelSelect.appendChild(option.cloneNode(true));
          hasValidModels = true;
        }
      });

      modelSelect.disabled = !hasValidModels;
      modelSelect.value = ''; // Reset về mặc định
    }

    function validate() {
      // Kiểm tra tất cả các trường đã được chọn chưa
      const isComplete = productSelect.value && yearSelect.value && makeSelect.value && modelSelect.value;
      
      if (isComplete) {
        btn.disabled = false;
        btn.classList.add('enabled');
      } else {
        btn.disabled = true;
        btn.classList.remove('enabled');
      }
    }

    // Lắng nghe sự kiện
    productSelect.addEventListener('change', validate);
    yearSelect.addEventListener('change', validate);
    
    makeSelect.addEventListener('change', function () {
      filterModels(this.value);
      validate();
    });
    
    modelSelect.addEventListener('change', validate);

    // Chuyển hướng khi nhấn nút GO
    btn.addEventListener('click', function () {
      if (btn.disabled) return;
      
      const url = `/products/${productSelect.value}?year=${encodeURIComponent(yearSelect.value)}&make=${encodeURIComponent(makeSelect.value)}&model=${encodeURIComponent(modelSelect.value)}`;
      window.location.href = url;
    });
  });
</script>

