{% liquid
  assign container = section.settings.container
  if container == 'w-full'
    assign container = 'container-full'
  endif
%}

<div
  class="see-action-section"
  id="SeeAction-{{ section.id }}"
  style="background-color: {{ section.settings.bg_color }}; padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;"
>
  <div class="{{ container }}">
    <div class="sa-header">
      <h2 style="color: {{ section.settings.heading_color }};">{{ section.settings.heading }}</h2>
      {% if section.settings.subheading != blank %}
        <p style="color: {{ section.settings.subheading_color }};">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="sa-container">
      <button class="sa-arrow prev" onclick="moveSeeAction('{{ section.id }}', -1)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M15 18l-6-6 6-6"/>
        </svg>
      </button>

      <div class="sa-track" id="SeeActionTrack-{{ section.id }}">
        {% for block in section.blocks %}
          <div class="sa-slide" {{ block.shopify_attributes }}>
            <div class="sa-video-wrapper" onclick="playSAVideo(this)">
              {% if block.settings.video != blank %}
                {{
                  block.settings.video
                  | video_tag: image_size: '600x', loop: true, muted: false, controls: false, class: 'sa-video-el'
                }}
              {% else %}
                {{ 'collection' | placeholder_svg_tag: 'placeholder-svg' }}
              {% endif %}

              <div class="sa-play-overlay">
                <svg viewBox="0 0 68 48" class="yt-play-btn">
                  <path class="yt-play-bg" d="M66.52,7.74c-0.78-2.93-2.49-5.41-5.42-6.19C55.79,.13,34,0,34,0S12.21,.13,6.9,1.55 C3.97,2.33,2.27,4.81,1.48,7.74C0.06,13.05,0,24,0,24s0.06,10.95,1.48,16.26c0.78,2.93,2.49,5.41,5.42,6.19 C12.21,47.87,34,48,34,48s21.79-0.13,27.1-1.55c2.93-0.78,4.64-3.26,5.42-6.19C67.94,34.95,68,24,68,24S67.94,13.05,66.52,7.74z" fill="#FF0000"></path><path d="M 45,24 27,14 27,34" fill="#fff"></path>
                </svg>
              </div>

              {% if block.settings.caption != blank %}
                <div class="sa-caption">
                  <span>{{ block.settings.caption | newline_to_br }}</span>
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>

      <button class="sa-arrow next" onclick="moveSeeAction('{{ section.id }}', 1)">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    </div>

    <div class="sa-progress-container">
      <div class="sa-progress-bg">
        <div class="sa-progress-bar" id="SeeActionProgress-{{ section.id }}"></div>
      </div>
    </div>
  </div>
</div>

<style>
    .see-action-section {
      font-family: inherit;
    }
    .sa-header {
      text-align: center;
      margin-bottom: 40px;
      padding: 0 20px;
    }
    .sa-header h2 {
      font-size: 28px;
      font-weight: 900;
      text-transform: uppercase;
      margin-bottom: 10px;
    }
    .sa-header p {
      font-size: 16px;
      margin: 0;
    }

    .sa-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    position: relative;
    padding: 0 50px;
  }

    .sa-arrow {
      background: transparent;
      border: none;
      cursor: pointer;
      width: 40px;
      height: 40px;
      display: flex;
      align-items: center;
      justify-content: center;
      color: #111;
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 2;
      transition: transform 0.2s;
    }
    .sa-arrow:hover { transform: translateY(-50%) scale(1.1); }
    .sa-arrow.prev { left: 5px; }
    .sa-arrow.next { right: 5px; }
    .sa-arrow svg { width: 24px; height: 24px; }

    .sa-track {
      display: flex;
      gap: 20px;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch; /* Tăng độ mượt cho iOS */
      scrollbar-width: none;
      width: 100%;
    }
    .sa-track::-webkit-scrollbar { display: none; }

    .sa-slide {
      flex: 0 0 calc(33.333% - 13.33px);
      scroll-snap-align: start;
    }

    .sa-video-wrapper {
      position: relative;
      width: 100%;
      aspect-ratio: 9 / 16;
      background: #000;
      border-radius: 12px;
      overflow: hidden;
      cursor: pointer;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .sa-video-el {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .sa-play-overlay {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 60px;
      height: auto;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }
    .sa-video-wrapper.is-playing .sa-play-overlay {
      opacity: 0;
    }

    .sa-caption {
      position: absolute;
      bottom: 30px;
      left: 0;
      width: 100%;
      text-align: center;
      pointer-events: none;
      padding: 0 15px;
    }
    .sa-caption span {
      background-color: rgba(0, 0, 0, 0.6);
      color: #fff;
      padding: 6px 12px;
      border-radius: 4px;
      font-size: 14px;
      line-height: 1.4;
      display: inline-block;
    }

    /* Progress Bar Styles */
    .sa-progress-container {
      max-width: 300px;
      margin: 40px auto 0 auto;
      padding: 0 20px;
    }
    .sa-progress-bg {
      width: 100%;
      height: 3px;
      background-color: #d1d1d1;
      border-radius: 2px;
      position: relative;
      overflow: hidden;
    }
    .sa-progress-bar {
      position: absolute;
      top: 0;
      left: 0;
      height: 100%;
      background-color: #111;
      width: 0%;
      border-radius: 2px;
      /* Chỉnh ease-in-out để thanh trượt chạy êm hơn */
      transition: width 0.4s ease-in-out;
    }

    .placeholder-svg { background: #333; fill: #555; width: 100%; height: 100%; }

    /* Responsive */
    @media (max-width: 900px) {
      .sa-slide { flex: 0 0 calc(50% - 10px); }
    }
    @media (max-width: 600px) {
      .sa-slide { flex: 0 0 100%; }
      .sa-container { padding: 0 40px; }
    }
</style>

<script>
  function playSAVideo(wrapper) {
    const video = wrapper.querySelector('video');
    if (!video) return;

    document.querySelectorAll('.sa-video-wrapper.is-playing').forEach((el) => {
      if (el !== wrapper) {
        const v = el.querySelector('video');
        if (v) {
          v.pause();
          v.removeAttribute('controls');
        }
        el.classList.remove('is-playing');
      }
    });

    if (video.paused) {
      video.play();
      wrapper.classList.add('is-playing');
    } else {
      video.pause();
      wrapper.classList.remove('is-playing');
    }
  }

  function moveSeeAction(sectionId, direction) {
    const track = document.getElementById(`SeeActionTrack-${sectionId}`);
    if (!track) return;

    const slide = track.querySelector('.sa-slide');
    if (!slide) return;

    const gap = parseFloat(getComputedStyle(track).gap || 0);
    const slideWidth = slide.clientWidth + gap;

    // Tính toán chính xác vị trí cuộn tiếp theo để tránh trượt lửng lơ
    const currentScroll = track.scrollLeft;
    // Làm tròn vị trí hiện tại để đảm bảo bắt đầu từ 1 slide trọn vẹn
    const currentIndex = Math.round(currentScroll / slideWidth);
    const nextScrollPos = (currentIndex + direction) * slideWidth;

    track.scrollTo({
      left: nextScrollPos,
      behavior: 'smooth',
    });
  }

  function updateProgressBar(sectionId, totalBlocks) {
    const track = document.getElementById(`SeeActionTrack-${sectionId}`);
    const progressBar = document.getElementById(`SeeActionProgress-${sectionId}`);
    if (!track || !progressBar || totalBlocks === 0) return;

    const slide = track.querySelector('.sa-slide');
    if (!slide) return;

    const gap = parseFloat(getComputedStyle(track).gap || 0);
    const slideWidth = slide.clientWidth + gap;

    const visibleSlides = Math.round(track.clientWidth / slideWidth);
    let currentIndex = Math.round(track.scrollLeft / slideWidth);

    let activeCount = currentIndex + visibleSlides;
    if (activeCount > totalBlocks) activeCount = totalBlocks;

    let percentage = (activeCount / totalBlocks) * 100;
    progressBar.style.width = `${percentage}%`;
  }

  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.sa-track').forEach((track) => {
      const sectionId = track.id.replace('SeeActionTrack-', '');
      const totalBlocks = track.querySelectorAll('.sa-slide').length;

      updateProgressBar(sectionId, totalBlocks);

      track.addEventListener('scroll', () => {
        updateProgressBar(sectionId, totalBlocks);
      });

      window.addEventListener('resize', () => {
        updateProgressBar(sectionId, totalBlocks);
      });
    });
  });
</script>

{% schema %}
{
  "name": "See In Action Slider",
  "settings": [
    {
      "type": "select",
      "id": "container",
      "label": "Container type",
      "default": "container-fluid",
      "options": [
        { "value": "container-fluid", "label": "Default" },
        { "value": "container", "label": "Boxed" },
        { "value": "w-full", "label": "Full width" }
      ]
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SEE IN ACTION"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#111111"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Simple installs, real protection, and honest feedback — all caught on video."
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f0f0f0"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "video_block",
      "name": "Video Card",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Upload Video"
        },
        {
          "type": "textarea",
          "id": "caption",
          "label": "Caption Overlay",
          "default": "The seat covers\nwere pretty good."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "See In Action",
      "blocks": [
        { "type": "video_block" },
        { "type": "video_block" },
        { "type": "video_block" },
        { "type": "video_block" }
      ]
    }
  ]
}
{% endschema %}
