{{ 'rich-text.css' | asset_url | stylesheet_tag }}
{% liquid
  assign animation_effect = settings.animations
  assign animated = false
  if animation_effect != 'none'
    assign animated = true
    if section.settings.animations != 'inherit'
      assign animation_effect = section.settings.animations
    endif
  endif

  assign show_image = false
  if section.settings.image_1 != blank or section.settings.image_2 != blank or section.settings.image_3 != blank
    assign show_image = true
  endif
%}

{%- style -%}
  #m-section-{{ section.id }} {
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  /* Alignment settings - đảm bảo override CSS external */
  #m-section-{{ section.id }} .m-richtext__title {
    text-align: {{ section.settings.heading_alignment }} !important;
  }
  #m-section-{{ section.id }} .m-richtext__description {
    text-align: {{ section.settings.text_alignment }} !important;
  }
  #m-section-{{ section.id }} .m-richtext__button {
    text-align: {{ section.settings.button_alignment }} !important;
    {%- if section.settings.button_alignment == 'left' -%}
      justify-content: flex-start !important;
    {%- elsif section.settings.button_alignment == 'right' -%}
      justify-content: flex-end !important;
    {%- else -%}
      justify-content: center !important;
    {%- endif -%}
  }
 
.custom-rich-text-page-cover .m-richtext__title.h2 {
    font-weight: bold !important;
}
.how-are-coverland .m-richtext__title.h2 {
  font-weight: bold !important;
}


/* --- CSS Cập nhật cho Block Image & Video --- */
.m-richtext__image-block,
.m-richtext__video-block {
  margin: 1.5rem 0;
  width: 100%;
  position: relative;
  overflow: hidden;
}

/* Xử lý chiều cao (Section height) cho Image */
.m-richtext__image-block.height-adapt {
  aspect-ratio: var(--aspect-ratio-mobile);
}
@media (min-width: 768px) {
  .m-richtext__image-block.height-adapt {
    aspect-ratio: var(--aspect-ratio);
  }
}
.m-richtext__image-block.height-small { height: 40vh; }
.m-richtext__image-block.height-medium { height: 60vh; }
.m-richtext__image-block.height-large { height: 80vh; }
.m-richtext__image-block.height-fullscreen { height: 100vh; }

.m-richtext__image-block img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.m-image-block-link {
  display: block;
  width: 100%;
  height: 100%;
}

/* CSS cho Video */
.m-richtext__video-block video {
  width: 100%;
  height: auto;
  display: block;
  object-fit: cover;
}

/* Thêm transition nhẹ cho nút bấm khi di chuột */
.m-button {
  transition: opacity 0.3s ease;
}
.m-button:hover {
  opacity: 0.85;
}
{%- endstyle -%}

<section
  id="m-section-{{ section.id }}"
  class="m-section m-rich-text{% if show_image %} m-rich-text--show-images{% endif %} m-gradient m-color-{{ section.settings.color_scheme }} {{ section.settings.custom_class }}"
>
  <div class="{{ section.settings.container }} m-section-my m-section-py">
    <div class="m-richtext">
      {%- for block in section.blocks -%}
        {% case block.type %}
          {%- when 'video' -%}
            <div
              class="m-richtext__video-block {{ block.settings.container_type }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
              {% if animated %}
                data-cascade
                style="--animation-order: {{ forloop.index }};"
              {% endif %}
              {{ block.shopify_attributes }}
            >
              {%- if block.settings.video != null -%}
                {%- liquid 
                  assign autoplay = block.settings.autoplay
                  assign muted = false
                  if autoplay
                    assign muted = true
                  endif
                -%}
                {{ block.settings.video | video_tag: autoplay: autoplay, loop: true, muted: muted, controls: true, class: 'm:w-full m:h-auto m:block' }}
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'm-placeholder-svg m:w-full m:h-full' }}
              {%- endif -%}
            </div>

          {%- when 'image' -%}
            {% liquid
              assign image = block.settings.image
              assign mb_image = block.settings.mb_image | default: image
              assign image_link = block.settings.image_link
              
              assign aspect_ratio = image.aspect_ratio | default: 2.333
              assign aspect_ratio_mobile = mb_image.aspect_ratio | default: 1
              
              assign style_attr = ''
              if animated
                assign style_attr = style_attr | append: '--animation-order: ' | append: forloop.index | append: ';'
              endif
              if block.settings.section_height == 'adapt'
                assign style_attr = style_attr | append: '--aspect-ratio: ' | append: aspect_ratio | append: '; --aspect-ratio-mobile: ' | append: aspect_ratio_mobile | append: ';'
              endif
            %}

            <div
              class="m-richtext__image-block m-color-{{ block.settings.color_scheme }} {{ block.settings.container_type }} height-{{ block.settings.section_height }}{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
              {% if style_attr != blank %}style="{{ style_attr }}"{% endif %}
              {{ block.shopify_attributes }}
            >
              {% if image_link != blank %}<a href="{{ image_link }}" class="m-image-block-link">{% endif %}
              
              {% if image != blank or mb_image != blank %}
                <picture class="media-wrapper m:block m:w-full m:h-full">
                  {%- if block.settings.mb_image != blank -%}
                    <source
                      media="(max-width: 767px)"
                      srcset="{{ block.settings.mb_image | image_url: width: '400x' }} 400w, {{ block.settings.mb_image | image_url: width: '600x' }} 600w, {{ block.settings.mb_image | image_url: width: '800x' }} 800w"
                      width="{{ block.settings.mb_image.width }}"
                      height="{{ block.settings.mb_image.height }}"
                    >
                  {%- endif %}
                  {% liquid
                    assign fallback_image = image | default: mb_image
                    assign image_height = fallback_image.width | divided_by: fallback_image.aspect_ratio | round
                  %}
                  {{
                    fallback_image
                    | image_url: width: 3200
                    | image_tag:
                      loading: 'lazy',
                      width: fallback_image.width,
                      height: image_height,
                      sizes: '100vw',
                      widths: '300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000,2200,2400,2600,2800,3000,3200',
                      alt: fallback_image.alt,
                      class: 'm:w-full m:h-full m:object-cover'
                  }}
                </picture>
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'm-placeholder-svg m:w-full m:h-full' }}
              {% endif %}

              {% if image_link != blank %}</a>{% endif %}
            </div>

          {%- when 'heading' -%}
            {%- if block.settings.heading != blank -%}
              {%- liquid
                assign block_style = ''
                if animated
                  assign block_style = block_style | append: ' --animation-order: ' | append: forloop.index | append: ';'
                endif
              -%}
<h2
  class="m-richtext__title {{ block.settings.heading_size }} {% if animated %}m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
  style="text-align: {{ section.settings.heading_alignment }}; {% if block_style != blank %}{{ block_style }}{% endif %}"
  {% if animated %}data-cascade{% endif %}
  {{ block.shopify_attributes }}
>
                {{ block.settings.heading }}
              </h2>
            {% endif %}

          {%- when 'subheading' -%}
            {%- if block.settings.subheading != blank -%}
              <p
                class="m-richtext__subtitle{% if animated %} m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                {% if animated %}
                  data-cascade
                  style="--animation-order: {{ forloop.index }};"
                {% endif %}
                {{ block.shopify_attributes }}
              >
                {{ block.settings.subheading }}
              </p>
            {% endif %}

          {%- when 'text' -%}
            {%- if block.settings.text != blank -%}
              {%- liquid
                assign block_style = ''

                if animated
                  assign block_style = block_style | append: ' --animation-order: ' | append: forloop.index | append: ';'
                endif
              -%}
              <div
  class="m-richtext__description rte {% if animated %}m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
  style="text-align: {{ section.settings.text_alignment }}; {% if block_style != blank %}{{ block_style }}{% endif %}"
  {% if animated %}data-cascade{% endif %}
  {{ block.shopify_attributes }}
>
                {{ block.settings.text }}
              </div>
            {% endif %}

          {%- when 'button' -%}
            {%- if block.settings.button_label != blank -%}
              {%- liquid
                assign custom_btn_style = ''
                if block.settings.btn_bg_color != blank and block.settings.btn_bg_color != 'rgba(0,0,0,0)'
                  assign custom_btn_style = custom_btn_style | append: 'background-color: ' | append: block.settings.btn_bg_color | append: ' !important; border-color: ' | append: block.settings.btn_bg_color | append: ' !important;'
                endif
                if block.settings.btn_text_color != blank and block.settings.btn_text_color != 'rgba(0,0,0,0)'
                  assign custom_btn_style = custom_btn_style | append: ' color: ' | append: block.settings.btn_text_color | append: ' !important;'
                endif
                
                assign btn_justify = 'center'
                if section.settings.button_alignment == 'left'
                  assign btn_justify = 'flex-start'
                elsif section.settings.button_alignment == 'right'
                  assign btn_justify = 'flex-end'
                endif
              -%} 
              <div 
                class="m-richtext__button {% if animated %}m-scroll-trigger animate--{{ animation_effect }}{% endif %}"
                style="text-align: {{ section.settings.button_alignment }}; display: flex; justify-content: {{ btn_justify }}; width: 100%; {% if animated %}--animation-order: {{ forloop.index }};{% endif %}"
                {% if animated %}data-cascade{% endif %}
              >
                <a
                  href="{{ block.settings.button_link }}"
                  class="m-button {{ block.settings.button_style }} {{ block.settings.button_size }}"
                  {% if custom_btn_style != blank %}style="{{ custom_btn_style }}"{% endif %}
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.button_label -}}
                </a>
              </div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
  {% if show_image %}
    <div class="m-rich-text__images">
      <div class="{{ section.settings.container }} m-rich-text__images-container">
        <div class="m-rich-text__images-wrapper">
          {% if section.settings.image_1 != blank %}
            <div class="m-rich-text__image m-rich-text__image-1">
              {% render 'responsive-image', image: section.settings.image_1, section_index: section.index, index: 1 %}
            </div>
          {% endif %}
          {% if section.settings.image_2 != blank %}
            <div class="m-rich-text__image m-rich-text__image-2">
              {% render 'responsive-image', image: section.settings.image_2, section_index: section.index, index: 1 %}
            </div>
          {% endif %}
          {% if section.settings.image_3 != blank %}
            <div class="m-rich-text__image m-rich-text__image-3">
              {% render 'responsive-image', image: section.settings.image_3, section_index: section.index, index: 1 %}
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% endif %}
</section>

