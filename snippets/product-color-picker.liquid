{% comment %}
  Independent Color Picker Snippet
  Handles Image Swatches and Label sync with main variant selection
{% endcomment %}

{% liquid
  assign color_option = null
  for option in product.options_with_values
    assign option_name = option.name | downcase
    if option_name == 'color' or option_name == 'màu sắc'
      assign color_option = option
      break
    endif
  endfor
%}

{% if color_option %}
  <div class="product-color-picker m-product-option" data-option-index="{{ color_option.position | minus: 1 }}">
    <div class="m-product-option--label">
      <span class="option-label--title">Color:</span>
      <span class="option-label--selected" id="selected-color-name">{{ color_option.selected_value }}</span>
    </div>

    <div class="m-product-option--content m:inline-flex m:flex-wrap">
      {% for value in color_option.values %}
        {% liquid
          assign input_id = 'color-' | append: section.id | append: '-' | append: forloop.index0
          assign variant = null
          for v in product.variants
            assign color_index = color_option.position | minus: 1
            if v.options[color_index] == value
              assign variant = v
              break
            endif
          endfor
          
          assign image_url = ''
          if variant and variant.image
            assign image_url = variant.image | image_url: width: 100
          endif
        %}
        
        <div class="m-product-option--node m-tooltip m-tooltip--top" data-value="{{ value | escape }}">
          <input 
            type="radio" 
            id="{{ input_id }}" 
            name="options[{{ color_option.name | escape }}]" 
            value="{{ value | escape }}"
            form="{{ product_form_id }}"
            class="m-product-option__input"
            data-option-value-id="{{ value.id }}"
            {% if color_option.selected_value == value %}checked{% endif %}
          >
          <label 
            for="{{ input_id }}" 
            class="m-product-option--node__label has-bg-img" 
            style="background-image: url('{{ image_url }}');"
            title="{{ value | escape }}"
          >
            {{ value }}
          </label>
          <span class="m-tooltip__content">{{ value }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
{% endif %}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const colorInputs = document.querySelectorAll('.product-color-picker input[type="radio"]');
    const colorLabel = document.getElementById('selected-color-name');
    
    colorInputs.forEach(input => {
      input.addEventListener('change', function() {
        if (this.checked && colorLabel) {
          colorLabel.textContent = this.value;
        }
      });
    });
  });
</script>
