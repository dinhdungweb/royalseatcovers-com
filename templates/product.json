    "shipping_policy_accordion_4AipWx": {
      "type": "shipping-policy-accordion",
      "blocks": {
        "policy_text_ieTDgX": {
          "type": "policy_text",
          "settings": {
            "title": "Seat Cover Warranty — 5 Years",
            "content": "<p>At Royal Auto Seat Covers, we are committed to delivering seat covers that combine exceptional quality, comfort, and durability. We stand behind the craftsmanship of our products, offering a comprehensive warranty for 5 years from the date of purchase.</p>"
          }
        },
        "policy_text_Xgjt8a": {
          "type": "policy_text",
          "settings": {
            "title": "Warranty Coverage",
            "content": "<p>Your warranty begins on the date of purchase and covers your product for 5 years, depending on its specific warranty term. Our warranty protects your seat cover against:</p><ul><li><strong>Seam & Stitching Integrity —</strong> If stitching comes undone or seams split under normal use, we'll replace it.</li><li><strong>Material Defects —</strong> Covers issues like fraying, weak fabric, or construction flaws that affect performance.</li><li><strong>Premature Fading —</strong> Significant fading or discoloration under normal use within the warranty period.</li><li><strong>Fit & Attachment Hardware —</strong> Defects in straps, hooks, or elastic that prevent proper installation or secure fit.</li><li><strong>Padding or Foam Failure —</strong> Unusual flattening, bunching, or material breakdown that impacts comfort or function.</li></ul>"
          }
        },
        "policy_text_j3Qfqy": {
          "type": "policy_text",
          "settings": {
            "title": "Warranty Term",
            "content": "<p>The warranty coverage begins from the original date of purchase. If a product is replaced under warranty, the replacement does not reset or extend the coverage period — the warranty continues from the original purchase date.</p>"
          }
        },
        "policy_text_BNNU9E": {
          "type": "policy_text",
          "settings": {
            "title": "How to Claim Your Warranty",
            "content": "<p>If you experience an issue covered under this warranty:</p><ul><li><strong>Contact Us —</strong> Reach our customer service team by phone or email with your order details and a short description of the issue.</li><li><strong>Provide Documentation —</strong> We may request photos or a brief video to help us evaluate your claim.</li><li><strong>Review & Approval —</strong> Our team will review your claim promptly.</li><li><strong>Replacement —</strong> If approved, a replacement seat cover will be shipped to you at no cost except for shipping.</li></ul>"
          }
        },
        "policy_text_NmFRG4": {
          "type": "policy_text",
          "settings": {
            "title": "Limitations & Exclusions",
            "content": "<p>This warranty does not cover:</p><ul><li>Damage from misuse, neglect, or improper installation.</li><li>Stains, spills, pet damage, burns, or cuts.</li><li>Fading caused by prolonged unprotected exposure to extreme sunlight.</li><li>Any alterations or modifications to the seat cover.</li></ul>"
          }
        },
        "policy_text_6pQpM7": {
          "type": "policy_text",
          "settings": {
            "title": "Our Promise to You",
            "content": "<p>Your satisfaction is our priority. This warranty is our commitment to ensuring you can enjoy your Royal Auto Seat Covers with complete confidence.</p><ul><li>Shipping fees are not included.</li><li>Starting from the second warranty claim, a restocking fee may apply.</li></ul><p>Thank you for choosing Royal Auto Seat Covers. We value your trust and look forward to serving you for years to come.</p>"
          }
        }
      },
