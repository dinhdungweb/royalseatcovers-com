    "shipping_policy_accordion_3eX8Dq": {
      "type": "shipping-policy-accordion",
      "blocks": {
        "policy_text_7bFazz": {
          "type": "policy_text",
          "settings": {
            "title": "FREE SHIPPING",
            "content": "<p>Shipping and Returns<br/><br/>Enjoy complimentary shipping on all standard orders. To ensure your items are perfectly prepped, orders typically process within 3–7 business days. Shop with confidence knowing every purchase is backed by our 30-day return policy for a full refund or exchange.<br/><br/>Standard Delivery:<br/>Orders are carefully prepared within 3–7 business days.<br/>Transit time: 7–17 business days<br/>Shipping cost: Free<br/><br/>Remote Locations & Exceptions:<br/>P.O. Boxes: Please provide a physical address at checkout, as we do not deliver to P.O. Box addresses.<br/>Shipping cost: A small surcharge may apply for select remote areas (calculated at checkout).<br/><br/>Returns & Exchanges:<br/>If you're not completely satisfied, you can return or exchange your items within 30 days of delivery. Please note that cancellations must be requested within 24 hours of placing your order.</p>"
          }
        }
      },
      "block_order": [
        "policy_text_7bFazz"
      ],
