    "ss_testimonial_28_Crpnb3": {
      "type": "ss-testimonial-28",
      "blocks": {
        "heading_8KtGpC": {
          "type": "heading",
          "settings": {
            "heading": "<h2>Trusted By 10<strong>0000+</strong> Customers Around The World</h2>",
            "heading_custom": false,
            "heading_font": "josefin_sans_n4",
            "heading_size": 48,
            "heading_size_mobile": 32,
