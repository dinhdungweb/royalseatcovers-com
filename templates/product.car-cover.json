f%(1000*60*60))\/(1000*60));\n    const seconds = Math.floor((diff%(1000*60))\/1000);\n\n    countdownEl.textContent =\n      String(hours).padStart(2,\"0\")+\":\"+\n      String(minutes).padStart(2,\"0\")+\":\"+\n      String(seconds).padStart(2,\"0\");\n  }\n\n  updateCountdown();\n  setInterval(updateCountdown,1000);\n\n})();\n<\/script>"}},"buy_buttons":{"type":"buy_buttons","settings":{"show_quantity_selector":true,"show_atc_button":true,"show_dynamic_checkout":false,"show_gift_card_recipient":true}},"quick_links_LCtBi7":{"type":"quick_links","settings":{"show_link_1":true,"text_1":"Features","url_1":"#shopify-section-template--29006125400409__tested_proven_4Qyih8","show_link_2":true,"text_2":"Comparison","url_2":"#shopify-section-template--29006125400409__feature_comparison_7ngx64","show_link_3":true,"text_3":"Reviews","url_3":"#judgeme_product_reviews","alignment":"center","text_color":"#111111","gap":30,"margin_bottom":15}},"trust_badge_NyBMd4":{"type":"trust_badge","settings":{"trust_badges_text":"<p>Guarantee safe & secure checkout<\/p>","trust_badges_image_width":"60%","position":"below"}},"collapsible_tab_DheN6k":{"type":"collapsible_tab","settings":{"heading":"Benefits","content":"","liquid":"{{ pages['benefit'].content }}","default_open":false}},"collapsible_tab_hCQQpV":{"type":"collapsible_tab","settings":{"heading":"Product Description","content":"<p><strong>SPECIFICATIONS<\/strong><\/p><p>Material: High Quality Nappa Leather<br\/>Suitable Season: All Seasons<br\/>Filling: Sponge<br\/>Including: Front Seat Cover*2 , Rear Seat Cover<br\/><br\/><strong>CAR SEAT COVER<\/strong><\/p><p><br\/>Seat Covers provides you with an opportunity to personalize and upgrade your car interior with style. Whether you are tired of the boring color that comes with the original design or simply desires a more luxurious interior, our wide range of designs has you covered.<br\/><br\/>Regardless of how big of a clean freak you are when it comes to your car, occasional spills are inevitable. Our seat covers are extremely durable, dirt resistant, and easy to clean. Providing you with protection, comfort, and style.<br\/><br\/><strong>OUR ADVANTAGE<\/strong><\/p><p><br\/>· Top grade material that guarantees comfort, style and safety, resistance to the elements<br\/>· Wear, abrasion, mildew and fade resistant<br\/>· Includes headrests, airbag cutouts, seat-belt sockets, and map pockets (as applicable for your vehicle)<br\/>· Same high quality material all around the seat with no substitution in material<br\/>· High quality buckles, zippers, and flaps for easy installation, secure fit, and long lasting repetitive use<br\/><strong><br\/>UNIVERSAL\/CUSTOM FIT<\/strong><\/p><p><br\/>Although our covers are designed to be universal fit, but due to the vast variety of car models available on the market, there will be a small number of car models that our universal fits will not fit. Please make sure to leave us your car Model ,Year and<br\/>Make when you place a order. Our manufacturing team and designers will modify the covers to provide you with a perfect fit.<\/p>","liquid":"{{product.description}}","default_open":false}},"collapsible_tab_mpVWGG":{"type":"collapsible_tab","settings":{"heading":"Includes","content":"<ul><li>Custom Car Cover<\/li><li>Wind-proof strap locks<\/li><li>Free Storage Bag ($30 value)<\/li><li>Installation and care manual<\/li><\/ul>","liquid":"","default_open":false}},"collapsible_tab_UrCNft":{"type":"collapsible_tab","settings":{"heading":"Specifications","content":"","liquid":"{{ pages['specifications'].content }}","default_open":false}},"collapsible_tab_jxmXz3":{"type":"collapsible_tab","settings":{"heading":"Support","content":"<p>Start Live Chat<\/p><p>info@royalseatcovers.com<\/p><p>1-720-389-2510<\/p>","liquid":"","default_open":false}}},"block_order":["judge_me_reviews_preview_badge_99FQ8j","badge_ChqgGj","title","price","text_with_icon_t86JmV","custom_countdown_mGG63L","free_included_items_NdCbfk","vehicle_s